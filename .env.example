# ─────────────────────────────────────────────────────
# Research Swarm — Environment Variables
# Copy this file to .env and fill in your API keys.
# ─────────────────────────────────────────────────────

# REQUIRED: Powers the LLM reasoning engine (default: OpenAI)
OPENAI_API_KEY=sk-your-openai-key-here

# OPTIONAL: Powers live web search via You.com Search API
YOU_API_KEY=your-you-dot-com-key-here

# OPTIONAL: For Anthropic models (if model.provider = anthropic in swarm_config.yml)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# OPTIONAL: For Google models (if model.provider = google in swarm_config.yml)
# GOOGLE_API_KEY=your-google-key-here
