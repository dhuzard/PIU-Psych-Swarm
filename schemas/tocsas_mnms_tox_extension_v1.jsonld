{
  "@context": {
    "schema": "http://schema.org/",
    "prov": "http://www.w3.org/ns/prov#",
    "mms": "https://github.com/dhuzard/piu-psych-swarm/blob/main/schemas/mms_schema_v1.jsonld#",
    "tocsas": "https://github.com/dhuzard/piu-psych-swarm/blob/main/schemas/tocsas_mnms_tox_extension_v1.jsonld#",
    "chebi": "http://purl.obolibrary.org/obo/CHEBI_",
    "uberon": "http://purl.obolibrary.org/obo/UBERON_",
    "ncit": "http://purl.obolibrary.org/obo/NCIT_",
    "efo": "http://www.ebi.ac.uk/efo/EFO_",

    "StudyContext": "mms:StudyContext",
    "StudyID": "schema:identifier",
    "Objective": "schema:description",
    "GLPStatus": "mms:GLPStatus",
    "Site": "schema:location",
    "ProtocolVersion": "schema:version",

    "StudyType": "tocsas:StudyType",
    "RegulatoryGuideline": "tocsas:RegulatoryGuideline",
    "GuidelineNumber": "tocsas:GuidelineNumber",
    "GuidelineVersion": "tocsas:GuidelineVersion",

    "AnimalDescriptors": "mms:AnimalDescriptors",
    "Species": "mms:Species",
    "Strain": "mms:Strain",
    "Sex": "schema:gender",
    "AgeAtStart": "tocsas:AgeAtStart",
    "BodyWeightAtStart": "tocsas:BodyWeightAtStart",
    "Source": "schema:seller",
    "MicrobiologicalStatus": "mms:MicrobiologicalStatus",
    "AcclimatizationPeriod": "tocsas:AcclimatizationPeriod",

    "Environment": "mms:Environment",
    "CageSystem": "mms:CageSystem",
    "GroupSize": "mms:GroupSize",
    "Enrichment": "mms:Enrichment",
    "DietWaterAccess": "mms:DietWaterAccess",
    "LDCycle": "mms:LDCycle",
    "Temperature": "tocsas:Temperature",
    "Humidity": "tocsas:Humidity",

    "TestArticle": "tocsas:TestArticle",
    "CompoundName": "schema:name",
    "CASNumber": "tocsas:CASNumber",
    "BatchLotNumber": "tocsas:BatchLotNumber",
    "Purity": "tocsas:Purity",
    "FormulationComposition": "tocsas:FormulationComposition",
    "FormulationStabilityConfirmed": "tocsas:FormulationStabilityConfirmed",
    "NominalConcentration": "tocsas:NominalConcentration",
    "AchievedConcentration": "tocsas:AchievedConcentration",

    "DosingAndExposure": "tocsas:DosingAndExposure",
    "DoseGroup": "tocsas:DoseGroup",
    "DoseLevel": "tocsas:DoseLevel",
    "DoseUnit": "tocsas:DoseUnit",
    "RouteOfAdministration": "tocsas:RouteOfAdministration",
    "DosingFrequency": "tocsas:DosingFrequency",
    "DosingSchedule": "tocsas:DosingSchedule",
    "DosingDurationDays": "tocsas:DosingDurationDays",
    "VolumeAdministered": "tocsas:VolumeAdministered",
    "Vehicle": "tocsas:Vehicle",
    "VehicleComposition": "tocsas:VehicleComposition",
    "ConcurrentVehicleControl": "tocsas:ConcurrentVehicleControl",
    "RecoveryGroupIncluded": "tocsas:RecoveryGroupIncluded",
    "RecoveryPeriodDays": "tocsas:RecoveryPeriodDays",
    "SatelliteGroupIncluded": "tocsas:SatelliteGroupIncluded",

    "Toxicokinetics": "tocsas:Toxicokinetics",
    "TKCollected": "tocsas:TKCollected",
    "TKSampleType": "tocsas:TKSampleType",
    "AUC": "tocsas:AUC",
    "Cmax": "tocsas:Cmax",
    "Tmax": "tocsas:Tmax",
    "HalfLife": "tocsas:HalfLife",
    "Bioavailability": "tocsas:Bioavailability",
    "AccumulationRatio": "tocsas:AccumulationRatio",
    "DoseProportionality": "tocsas:DoseProportionality",
    "NonlinearTKFlag": "tocsas:NonlinearTKFlag",

    "SamplingAndTiming": "mms:TimeAndProvenance",
    "SamplingTimePoints": "tocsas:SamplingTimePoints",
    "TerminalSacrificeDay": "tocsas:TerminalSacrificeDay",
    "NecropsyProcedure": "tocsas:NecropsyProcedure",

    "ClinicalPathology": "tocsas:ClinicalPathology",
    "HematologyPanel": "tocsas:HematologyPanel",
    "ClinicalChemistryPanel": "tocsas:ClinicalChemistryPanel",
    "UrinalysisPanel": "tocsas:UrinalysisPanel",
    "CoagulationPanel": "tocsas:CoagulationPanel",
    "AnalyticalMethod": "tocsas:AnalyticalMethod",
    "HistoricalControlDataAvailable": "tocsas:HistoricalControlDataAvailable",

    "OrganWeights": "tocsas:OrganWeights",
    "OrgansWeighed": "tocsas:OrgansWeighed",
    "AbsoluteWeight": "tocsas:AbsoluteWeight",
    "RelativeToBodyWeight": "tocsas:RelativeToBodyWeight",
    "RelativeToBrainWeight": "tocsas:RelativeToBrainWeight",

    "Histopathology": "tocsas:Histopathology",
    "OrgansExamined": "tocsas:OrgansExamined",
    "PathologyTerm": "tocsas:PathologyTerm",
    "INHANDNomenclatureUsed": "tocsas:INHANDNomenclatureUsed",
    "INHANDReference": "tocsas:INHANDReference",
    "MorphologicalQualifier": "tocsas:MorphologicalQualifier",
    "SeverityGrade": "tocsas:SeverityGrade",
    "GradingSystem": "tocsas:GradingSystem",
    "Distribution": "tocsas:Distribution",
    "Incidence": "tocsas:Incidence",
    "TreatmentRelationship": "tocsas:TreatmentRelationship",
    "PathologistQualification": "tocsas:PathologistQualification",
    "PathologyPeerReview": "tocsas:PathologyPeerReview",

    "Interpretation": "tocsas:Interpretation",
    "NOAELMgKgDay": "tocsas:NOAELMgKgDay",
    "LOAELMgKgDay": "tocsas:LOAELMgKgDay",
    "AdversityJudgment": "tocsas:AdversityJudgment",
    "AdversityCriteria": "tocsas:AdversityCriteria",
    "AdversityCriteriaReference": "tocsas:AdversityCriteriaReference",
