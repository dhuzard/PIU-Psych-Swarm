# ─────────────────────────────────────────────────────────────────────────────
# Research Swarm — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE THIS FILE:
#   1. Copy it to a new file named exactly ".env"  (cp .env.example .env)
#   2. Replace the placeholder values with your real API keys
#   3. Save the file — it will be loaded automatically when you run the swarm
#
# IMPORTANT: Never commit your .env file to git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED: OpenAI API Key ─────────────────────────────────────────────────
#
# Get your key at: https://platform.openai.com/api-keys
#   1. Sign in (or create an account)
#   2. Go to "API keys" in the left menu
#   3. Click "Create new secret key"
#   4. Copy the key (starts with "sk-") — you can only see it once
#   5. Paste it below, replacing sk-your-openai-key-here
#
# COST: GPT-4o costs approximately $2.50 per million input tokens and
#       $10.00 per million output tokens (2025 pricing).
#       A typical research query costs $1–$5. Complex synthesis: $5–$15.
#
# SAFETY: Set a monthly spending limit at https://platform.openai.com/settings
#         to prevent unexpected charges.
#
OPENAI_API_KEY=sk-your-openai-key-here


# ── OPTIONAL: You.com API Key (enables live web search) ──────────────────────
#
# Without this key, the swarm relies on PubMed and Semantic Scholar only.
# With it, agents can also search the live web and retrieve recent news and
# preprints not yet indexed in academic databases.
#
# Get your key at: https://you.com/api
#
YOU_API_KEY=your-you-dot-com-key-here


# ── OPTIONAL: Anthropic API Key ──────────────────────────────────────────────
#
# Use Anthropic models instead of (or alongside) OpenAI.
# To switch all agents to Claude: in swarm_config.yml, set:
#   model:
#     provider: "anthropic"
#     name: "claude-opus-4-6"
#     env_key: "ANTHROPIC_API_KEY"
#
# Get your key at: https://console.anthropic.com/api-keys
#
# ANTHROPIC_API_KEY=your-anthropic-key-here


# ── OPTIONAL: Google API Key ─────────────────────────────────────────────────
#
# Use Google Gemini models instead of OpenAI.
# To switch: in swarm_config.yml, set provider: "google", name: "gemini-1.5-pro"
#
# Get your key at: https://aistudio.google.com/app/apikey
#
# GOOGLE_API_KEY=your-google-key-here
