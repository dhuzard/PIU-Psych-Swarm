root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml}]
indent_size = 2

[*.{json,jsonld}]
indent_size = 2

[*.md]
# Trailing spaces are meaningful in Markdown (line break = two spaces)
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
indent_size = 4
