    "StudyEndDate": "prov:endedAtTime",
    "BatchID": "mms:BatchID",
    "DataVersion": "schema:version",
    "QAStatus": "tocsas:QAStatus",
    "AnalysisDate": "tocsas:AnalysisDate",
    "ResponsibleAnalyst": "prov:wasAttributedTo",

    "MissingMetadata": "tocsas:MissingMetadata",
    "MissingElement": "tocsas:MissingElement",
    "MissingElementPriority": "tocsas:MissingElementPriority",
    "InterpretiveConsequence": "tocsas:InterpretiveConsequence",

    "EpistemicTag": "tocsas:EpistemicTag",
    "EvidenceSource": "tocsas:EvidenceSource",
    "PMID": "tocsas:PMID",
    "DOI": "schema:identifier"
